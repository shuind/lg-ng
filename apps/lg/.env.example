# Runtime data. Production should mount this path to persistent storage.
LG_DATA_DIR=

# Required in production. Use a stable 32-byte base64 or 64-char hex value.
APP_ENCRYPTION_KEY=

# Optional legacy invitation codes. New codes and per-code limits can be managed in /admin.
LG_INVITE_CODES=

# Comma-separated admin emails that can access /admin.
LG_ADMIN_EMAILS=

# Optional default OpenAI-compatible provider for CLI/server fallback.
NG_PROVIDER=
NG_API_KEY=
NG_BASE_URL=
NG_MODEL=

# DeepSeek keys are configured per user in the Settings page.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional legacy platform model defaults. Admin-managed platform configs in /admin are preferred.
DEEPSEEK_PLATFORM_API_KEY=
DEEPSEEK_PLATFORM_BASE_URL=https://api.deepseek.com
DEEPSEEK_PLATFORM_MODEL=deepseek-v4-flash

# Optional platform trial quota.
LG_TRIAL_QUOTA_ENABLED=false
LG_TRIAL_QUOTA_TOTAL_CNY=20
LG_TRIAL_QUOTA_PER_USER_CNY=2
LG_TRIAL_QUOTA_CACHE_HIT_PRICE_PER_MILLION_CNY=0
LG_TRIAL_QUOTA_CACHE_MISS_PRICE_PER_MILLION_CNY=0
LG_TRIAL_QUOTA_OUTPUT_PRICE_PER_MILLION_CNY=0
